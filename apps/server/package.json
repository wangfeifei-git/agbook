{
  "name": "@agbook/server",
  "version": "0.1.1",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "bin": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "bundle": "node ../../scripts/bundle-server.mjs",
    "pkg": "node ../../scripts/pkg-server.mjs"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/static": "^7.0.4",
    "better-sqlite3": "^11.3.0",
    "fastify": "^4.28.1",
    "nanoid": "^5.0.7",
    "undici": "^6.19.8",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.5.4",
    "@yao-pkg/pkg": "^6.3.0",
    "esbuild": "^0.24.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4"
  },
  "pkg": {
    "assets": [
      "../../node_modules/better-sqlite3/build/Release/*.node",
      "../../node_modules/bindings/**/*",
      "../../node_modules/file-uri-to-path/**/*",
      "node_modules/better-sqlite3/build/Release/*.node",
      "node_modules/bindings/**/*",
      "node_modules/file-uri-to-path/**/*"
    ]
  }
}
