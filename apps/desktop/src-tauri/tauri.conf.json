{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "agbook",
  "version": "0.1.0",
  "identifier": "com.agbook.app",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "npm -w @agbook/web run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../../web/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "agbook",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/agbook-server"
    ]
  }
}
